<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      background: rgba(30, 30, 30, 0.95);
      border: 1px solid #444;
      border-radius: 4px;
      font-family: 'Segoe UI', sans-serif;
      color: #fff;
      display: flex;
      flex-direction: column;
      height: 100vh;
      overflow: hidden;
    }
    
    .drag-handle {
      height: 8px;
      background: transparent;
      -webkit-app-region: drag;
      transition: background 0.15s ease;
    }
    
    body:hover .drag-handle {
      background: rgba(255, 255, 255, 0.08);
      box-shadow: inset 0 1px 3px rgba(0,0,0,0.3);
    }
    
    #messages {
      flex: 1;
      background: rgba(0, 0, 0, 0.2);
      padding: 4px;
      overflow-y: auto;
      font-size: 12px;
      line-height: 1.3;
      -webkit-app-region: no-drag;
    }
    
    .message {
      padding: 1px 4px;
      word-wrap: break-word;
      border-bottom: 1px solid #3a3a3a;
    }
    
    .message:last-child {
      border-bottom: none;
    }
    
    .own-message {
      color: #8bc34a;
    }
    
    #input {
      width: 100%;
      padding: 4px 6px;
      background: rgba(0, 0, 0, 0.3);
      border: none;
      border-top: 1px solid #444;
      color: white;
      font-size: 12px;
      outline: none;
      -webkit-app-region: no-drag;
    }
    
    #input:focus {
      background: rgba(0, 0, 0, 0.5);
    }
    
    #messages::-webkit-scrollbar {
      width: 4px;
    }
    
    #messages::-webkit-scrollbar-track {
      background: transparent;
    }
    
    #messages::-webkit-scrollbar-thumb {
      background: #555;
      border-radius: 2px;
    }
  </style>
</head>
<body>
  <div class="drag-handle"></div>
  <div id="messages"></div>
  <input type="text" id="input" placeholder="Сообщение..." autofocus>
  
  <script>
    const { ipcRenderer } = require('electron');
    const messagesDiv = document.getElementById('messages');
    const input = document.getElementById('input');
    
    function addMessage(text, isOwn = false) {
      const msg = document.createElement('div');
      msg.className = 'message' + (isOwn ? ' own-message' : '');
      msg.textContent = text;
      messagesDiv.appendChild(msg);
      messagesDiv.scrollTop = messagesDiv.scrollHeight;
      while (messagesDiv.children.length > 100) {
        messagesDiv.removeChild(messagesDiv.firstChild);
      }
    }
    
    // Получение сообщений из чата (все сообщения)
    ipcRenderer.on('overlay-message', (event, text) => {
      // Определяем своё или чужое по формату "Имя: текст"
      // Можно настроить под ваш формат
      const isOwn = text.startsWith('1111:'); // Замените на ваше имя пользователя
      addMessage(text, isOwn);
    });
    
    ipcRenderer.on('focus-input', () => {
      input.focus();
    });
    
    function sendMessage() {
      const text = input.value.trim();
      if (text) {
        // НЕ добавляем в список локально - только отправляем в чат
        // Чат сам вернёт сообщение через overlay-message
        ipcRenderer.send('overlay-input', text);
        input.value = '';
      }
    }
    
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') sendMessage();
      else if (e.key === 'Escape') ipcRenderer.send('hide-overlay');
    });
    
    addMessage('Готово');
  </script>
</body>
</html>