{
  "name": "nsqcue-updater",
  "version": "1.0.0",
  "description": "Установщик аддонов Ночная Стража",
  "main": "main/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win64": "electron-builder --win portable --x64",
    "build:linux": "electron-builder --linux AppImage --x64"
  },
  "build": {
    "appId": "com.nsqcue.updater",
    "productName": "Ночная стража: установщик аддонов",
    "icon": "assets/icon.png",
    "extraResources": [
      {
        "from": "global-mouse-hook/target/release/global_mouse_hook",
        "to": "global_mouse_hook"
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "portable": {
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "unicode": true,
      "warningsAsErrors": false
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ],
      "category": "Utility",
      "synopsis": "Установщик аддонов Ночная Стража"
    }
  },
  "dependencies": {
    "axios": "^1.6.8",
    "fs-extra": "^11.2.0",
    "unzipper": "^0.10.14"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.3.0",
    "electron": "^22.3.27",
    "electron-builder": "^24.13.3"
  }
}