{
  "name": "NSQCuE",
  "version": "33.0.0",
  "description": "Установщик аддонов Ночная Стража",
  "main": "main/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win64": "electron-builder --win portable --x64",
    "build:linux": "electron-builder --linux AppImage --x64"
  },
  "build": {
    "appId": "com.nsqcue.updater",
    "productName": "Ночная стража: установщик аддонов",
    "executableName": "NSQCuE-29",
    "icon": "assets/icon.png",
    "extraResources": [
      {
        "from": "global-mouse-hook.exe",
        "to": "global-mouse-hook.exe"
      },
      {
        "from": "chat-overlay.exe",
        "to": "chat-overlay.exe"
      },
      {
        "from": "baseSounds/",
        "to": "baseSounds/"
      }
    ],
    "files": [
      "main/**/*",
      "renderer/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}",
      "unicode": true,
      "warningsAsErrors": false,
      "requestExecutionLevel": "user"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility",
      "synopsis": "Установщик аддонов Ночная Стража"
    }
  },
  "dependencies": {
    "axios": "^1.6.8",
    "fs-extra": "^11.2.0",
    "unzipper": "^0.10.14"
  },
  "devDependencies": {
    "electron": "^22.3.27",
    "electron-builder": "^24.13.3"
  }
}