{
  "name": "nsqcue-updater",
  "version": "1.0.0",
  "description": "Установщик аддонов Ночная Стража",
  "main": "main/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win64": "electron-builder --win nsis --x64",
    "build:linux": "electron-builder --linux AppImage --x64"
  },
  "build": {
    "appId": "com.nsqcue.updater",
    "productName": "Ночная стража: установщик аддонов",
    "icon": "assets/icon.png",
    "extraResources": [
      {
        "from": "global-mouse-hook.exe",
        "to": "global-mouse-hook.exe"
      },
      {
        "from": "baseSounds/",
        "to": "baseSounds/"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "artifactName": "NSQCuE-29.exe",
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NSQC Installer",
      "uninstallDisplayName": "Ночная стража: установщик аддонов",
      "warningsAsErrors": false
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ],
      "category": "Utility",
      "synopsis": "Установщик аддонов Ночная Стража"
    }
  },
  "dependencies": {
    "axios": "^1.6.8",
    "fs-extra": "^11.2.0",
    "unzipper": "^0.10.14"
  },
  "devDependencies": {
    "electron": "^22.3.27",
    "electron-builder": "^24.13.3"
  }
}